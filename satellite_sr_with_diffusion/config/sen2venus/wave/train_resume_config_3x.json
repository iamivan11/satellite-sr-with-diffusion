{
    "name": "s2v_3x_wave_r_",
    "gpu_ids": [
        0
    ],
    "path": {
        "log": "logs",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": "/content/drive/MyDrive/checkpoint/I___000_E__"
    },
    "datasets": {
        "train": {
            "name": "sen2venus_3x_train",
            "dataroot": "/content/SEN2VENUS_3x/train",
            "datatype": "img",
            "batch_size": 32,
            "num_workers": 8,
            "use_shuffle": true,
            "data_len": -1
        },
        "val": {
            "name": "sen2venus_3x_val",
            "dataroot": "/content/SEN2VENUS_3x/val",
            "datatype": "img",
            "data_len": 100
        }
    },
    "model": {
        "which_model_G": "wave",
        "finetune_norm": false,
        "unet": {
            "in_channel": 24,
            "out_channel": 12,
            "inner_channel": 64,
            "channel_mults": [
                1,
                2,
                4,
                8,
                8
            ],
            "attn_res": [
                12, 6
            ],
            "res_blocks": 2,
            "dropout": 0.1
        },
        "beta_schedule": {
            "train": {
                "schedule": "linear",
                "n_timestep": 2000,
                "linear_start": 1e-06,
                "linear_end": 0.01
            },
            "val": {
                "schedule": "linear",
                "n_timestep": 500,
                "linear_start": 1e-06,
                "linear_end": 0.01
            }
        },
        "diffusion": {
            "image_size": 96,
            "channels": 3,
            "conditional": true
        }
    },
    "train": {
        "n_iter": 200000,
        "val_freq": 10000,
        "save_checkpoint_freq": 10000,
        "print_freq": 500,
        "optimizer": {
            "type": "adamw",
            "lr": 5e-5,
            "weight_decay": 0.0001
        },
        "gradient_clipping": true,
        "clip_value": 1.0,
        "use_lpips": false,
        "lpips_weight": 0.05
    },
    "wandb": {
        "project": "train__"
    }
}
